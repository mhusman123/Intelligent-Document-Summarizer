# ─── Copy this file to .env and fill in your values ───

# Application
APP_NAME="Intelligent Document Summarizer"
APP_VERSION="1.0.0"
DEBUG=False

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# Summarization Model (HuggingFace)
SUMMARIZER_MODEL=facebook/bart-large-cnn
SUMMARIZER_MIN_LENGTH=50
SUMMARIZER_MAX_LENGTH=300

# QA Model (HuggingFace)
QA_MODEL=deepset/roberta-base-squad2

# Keyword Extraction
KEYWORD_TOP_N=10
